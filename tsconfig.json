{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "src/ui/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
